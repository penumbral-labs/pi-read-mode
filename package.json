{
  "name": "@penumbral-labs/pi-read-mode",
  "version": "1.0.0",
  "description": "Scroll through conversation history while composing a multiline follow-up",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "read-mode",
    "terminal",
    "composer"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@types/node": "^24.0.0",
    "jiti": "^2.7.0",
    "typescript": "^5.8.3"
  },
  "files": [
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "Penumbral Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/penumbral-labs/pi-read-mode.git"
  },
  "bugs": {
    "url": "https://github.com/penumbral-labs/pi-read-mode/issues"
  },
  "homepage": "https://github.com/penumbral-labs/pi-read-mode#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
